# Server (never commit a real .env)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blindspot
ANTHROPIC_API_KEY=
MODEL_ID=claude-haiku-4-5-20251001

# OpenAI embeddings — powers the clue audit band + suspicion voting.
# Without this key, embeddings fall back to a non-semantic local stub.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional: LangSmith tracing (traces are tagged with the room code)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=blindspot
